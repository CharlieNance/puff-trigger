# Copy this to .env and adjust values for your environment.

# Serial device for PMS5003 (Zero W = /dev/ttyS0, Pi 5 = /dev/ttyAMA0)
SERIAL_PORT=/dev/ttyS0

# ALSA card number for USB speaker (run `aplay -l` to confirm)
ALSA_CARD=1

# PM2.5 spike in µg/m³ above baseline required to trigger playback
PM25_TRIGGER_THRESHOLD=50

# Seconds to wait after a trigger before allowing another
TRIGGER_COOLDOWN_SECONDS=10

# Path to directory containing WAV audio files
AUDIO_DIR=audio

# FastAPI port
PORT=8000

# Allowed CORS origins (comma-separated, no spaces)
CORS_ORIGINS=http://localhost:5173
